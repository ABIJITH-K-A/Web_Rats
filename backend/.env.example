# ============================================
# TN WEB RATS - Backend Environment Variables
# ============================================

# Server Configuration
PORT=8787
NODE_ENV=development

# CORS Origins (comma-separated list of allowed frontend URLs)
CORS_ORIGIN=http://localhost:5173,https://tnwebrats.vercel.app

# ============================================
# Firebase Admin SDK (Required)
# Get these from Firebase Console → Project Settings → Service Accounts
# ============================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----\n"

# ============================================
# Cashfree Payment Gateway (Required for payments)
# Get from: https://merchant.cashfree.com/merchants/signup
# ============================================
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# PostgreSQL Database (Required for wallet/financial features)
# FREE OPTIONS:
# 1. Neon (https://neon.tech) - 500MB storage, no credit card required
# 2. Supabase (https://supabase.com) - 500MB storage, generous free tier
# 3. Render (https://render.com) - Free tier available
# ============================================
POSTGRES_URL=postgresql://username:password@host:port/database?sslmode=require

# ============================================
# Redis (Optional - for caching/sessions)
# FREE OPTION: Upstash (https://upstash.com) - 10,000 requests/day free
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Email (Gmail SMTP) - Optional for email notifications
# Use App Password from Google Account → Security → 2FA → App passwords
# ============================================
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ============================================
# WhatsApp (Twilio) - Optional for WhatsApp notifications
# Get from: https://www.twilio.com/try-twilio
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# ============================================
# URLs (Update for production)
# ============================================
BACKEND_URL=http://localhost:8787
FRONTEND_URL=http://localhost:5173
