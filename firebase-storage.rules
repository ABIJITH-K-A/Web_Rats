rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getOrder(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data;
    }

    function isOrderClient(orderId) {
      return isAuthenticated() && getOrder(orderId).userId == request.auth.uid;
    }

    function isAssignedWorker(orderId) {
      let order = getOrder(orderId);
      return isAuthenticated() && (
        order.assignedTo == request.auth.uid ||
        order.workerAssigned == request.auth.uid ||
        request.auth.uid in (order.assignedWorkers || [])
      );
    }

    function isEscalated(orderId) {
      let chat = get(/databases/$(database)/documents/chatThreads/$(orderId)).data;
      return chat.escalated == true;
    }

    function isAdminLikeRole() {
      return request.auth.token.role in ['admin', 'manager', 'owner', 'super_admin'];
    }

    // Valid file types for production
    function isValidFileType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('text/plain') ||
             request.resource.contentType.matches('application/zip') ||
             request.resource.contentType.matches('application/x-zip-compressed');
    }

    // Max 50MB file size
    function isValidFileSize() {
      return request.resource.size <= 50 * 1024 * 1024;
    }

    // References: client can upload, assigned worker + admins (if escalated) can read
    match /orders/{orderId}/references/{filename} {
      allow read: if isAuthenticated() && (
        isOrderClient(orderId) ||
        isAssignedWorker(orderId) ||
        (isEscalated(orderId) && isAdminLikeRole())
      );
      allow write: if isAuthenticated() && isOrderClient(orderId) && isValidFileType() && isValidFileSize();
    }

    // Deliverables: worker can upload, client can download
    match /orders/{orderId}/deliverables/{filename} {
      allow read: if isAuthenticated() && (
        isOrderClient(orderId) ||
        isAssignedWorker(orderId)
      );
      allow write: if isAuthenticated() && isAssignedWorker(orderId) && isValidFileType() && isValidFileSize();
    }

    // Revisions: both client and worker can upload
    match /orders/{orderId}/revisions/{filename} {
      allow read: if isAuthenticated() && (
        isOrderClient(orderId) ||
        isAssignedWorker(orderId)
      );
      allow write: if isAuthenticated() && (
        isOrderClient(orderId) ||
        isAssignedWorker(orderId)
      ) && isValidFileType() && isValidFileSize();
    }
  }
}
